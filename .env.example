# Backend
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@db:5432/enterprise_copilot
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=/app/data/uploads
VECTOR_STORE_PATH=/app/data/vector_store
CACHE_TTL_SECONDS=900
RETRIEVAL_TOP_K=4
RETRIEVAL_CANDIDATE_MULTIPLIER=3
HYBRID_SEMANTIC_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35
MAX_UPLOAD_SIZE_MB=20
MAX_CONTEXT_CHARACTERS=6000
MEMORY_WINDOW_SIZE=6
DEFAULT_ROLE=viewer

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Foundry / Mistral (used by test.py)
AZURE_AI_MISTRAL_ENDPOINT=https://aaaadmin1347-resource001.services.ai.azure.com/openai/v1/
AZURE_AI_MISTRAL_DEPLOYMENT=Mistral-Large-3
AZURE_AI_API_KEY=PASTE_YOUR_KEY_HERE
